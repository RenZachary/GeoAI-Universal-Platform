# Dependencies
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# Build outputs
dist/
out/
*.tsbuildinfo
package/
vendor/node-*
vendor/3rdParty_x64
vendor/GDAL
GeoAI-UP-v*
dist-bundled/

# Environment files (keep .env.example but ignore actual env files)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
workspace/database/*.db
workspace/database/*.db-shm
workspace/database/*.db-wal
workspace/data/local/
workspace/results/
workspace/temp/

# LLM related files
workspace/llm/config/

# Test coverage
coverage/
.nyc_output/

# TypeScript cache
.ts-node/

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# parcel-cache
.parcel-cache

# Next.js build output
.next

# Nuxt.js build output
.nuxt

# Vuepress build output
.vuepress/dist

# Serverless directories
.serverless/

# FuseBox cache
.fusebox/

# DynamoDB Local files
.dynamodb/

# TernJS port file
.tern-port

# Stores VSCode versions used for testing
.vscode-test

# Webpack cache
.cache/

# Vite cache
dev-dist/

# Temporary files
*.tmp
*.temp
.tmp/
.temp/
