# GeoAI-UP Server Configuration Template
# Copy this file to .env and update with your values

# Workspace directory (default: ./workspace)
# All application data including LLM config, plugins, results are stored here
WORKSPACE_DIR=./workspace

# Server port
PORT=3000

# Node environment (development | production)
NODE_ENV=development

# Frontend base URL (must match VITE_BASE_URL in web/.env)
# Set to /geo-ai if frontend is deployed under subdirectory
VITE_BASE_URL=/geo-ai

