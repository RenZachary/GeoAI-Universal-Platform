# GeoAI-UP Server Configuration

# Workspace directory (default: project root /workspace)
WORKSPACE_DIR=./workspace

# Server port
PORT=3000

# Node environment
NODE_ENV=development

# Frontend base URL (must match VITE_BASE_URL in web/.env)
VITE_BASE_URL=/geo-ai

# ============================================================================
# LLM Configuration
# ============================================================================

# LLM Provider: openai | anthropic | ollama
LLM_PROVIDER=openai

# OpenAI API Key (Get from https://platform.openai.com/api-keys)
# For development without API key, leave empty and system will use fallback mode
OPENAI_API_KEY=

# Model selection
LLM_MODEL=gpt-4

# LLM Parameters
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000
